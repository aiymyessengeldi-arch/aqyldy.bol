<!DOCTYPE html>
<html lang="kk">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Ақылды бол — Білім платформасы</title>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
  :root {
    --rose-50: #fff0f3;
    --rose-100: #ffe0e9;
    --rose-200: #ffc2d4;
    --rose-300: #ff9cb9;
    --rose-400: #ff6b97;
    --rose-500: #f7438a;
    --rose-600: #e0206e;
    --blush: #fde8ef;
    --cream: #fef7f9;
    --mocha: #4a2535;
    --dusty: #9c6b7e;
    --gold: #c9a96e;
    --text: #2d1420;
    --muted: #9c7080;
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    font-family: 'DM Sans', sans-serif;
    background: var(--cream);
    color: var(--text);
    overflow-x: hidden;
  }

  /* ── NOISE TEXTURE ── */
  body::before {
    content: '';
    position: fixed;
    inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.03'/%3E%3C/svg%3E");
    pointer-events: none;
    z-index: 999;
    opacity: .4;
  }

  /* ── NAV ── */
  nav {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 100;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 48px;
    height: 72px;
    background: rgba(254,247,249,.85);
    backdrop-filter: blur(16px);
    border-bottom: 1px solid rgba(255,156,185,.18);
  }

  .logo {
    display: flex;
    align-items: center;
    gap: 12px;
    text-decoration: none;
  }

  .logo-mark {
    flex-shrink: 0;
    width: 52px;
    height: 52px;
    border-radius: 50%;
    background: #f9c8de;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 4px 16px rgba(247,67,138,.22);
    overflow: hidden;
  }

  .logo-text-wrap {
    margin-left: 10px;
    line-height: 1;
  }
  .logo-name {
    font-family: 'Cormorant Garamond', serif;
    font-size: 24px;
    font-weight: 600;
    color: var(--mocha);
    letter-spacing: -.4px;
    display: block;
  }
  .logo-name em {
    font-style: italic;
    color: var(--rose-500);
  }
  .logo-sub {
    font-family: 'DM Sans', sans-serif;
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 2.5px;
    text-transform: uppercase;
    color: var(--dusty);
    display: block;
    margin-top: 3px;
  }

  nav ul {
    display: flex;
    gap: 36px;
    list-style: none;
  }

  nav ul a {
    font-size: 14px;
    font-weight: 500;
    color: var(--dusty);
    text-decoration: none;
    transition: color .2s;
    letter-spacing: .2px;
  }
  nav ul a:hover { color: var(--rose-500); }

  .nav-cta {
    display: flex;
    gap: 12px;
    align-items: center;
  }

  .btn-ghost {
    font-size: 14px;
    font-weight: 500;
    color: var(--mocha);
    background: none;
    border: none;
    cursor: pointer;
    padding: 8px 16px;
    border-radius: 8px;
    transition: background .2s;
  }
  .btn-ghost:hover { background: var(--rose-100); }

  .btn-primary {
    font-size: 14px;
    font-weight: 600;
    color: white;
    background: linear-gradient(135deg, #ff9cb9, #f7438a);
    border: none;
    cursor: pointer;
    padding: 10px 24px;
    border-radius: 50px;
    box-shadow: 0 4px 14px rgba(247,67,138,.3);
    transition: transform .2s, box-shadow .2s;
  }
  .btn-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(247,67,138,.4);
  }

  /* ── HERO ── */
  .hero {
    min-height: 100vh;
    display: flex;
    align-items: center;
    padding: 120px 48px 80px;
    position: relative;
    overflow: hidden;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 70% 60% at 80% 40%, rgba(255,156,185,.22) 0%, transparent 65%),
      radial-gradient(ellipse 50% 50% at 20% 70%, rgba(255,194,212,.18) 0%, transparent 60%),
      radial-gradient(ellipse 40% 40% at 60% 90%, rgba(247,67,138,.08) 0%, transparent 50%);
  }

  .hero-blob {
    position: absolute;
    border-radius: 50%;
    filter: blur(60px);
    animation: float 8s ease-in-out infinite;
  }
  .blob1 {
    width: 480px; height: 480px;
    background: rgba(255,156,185,.2);
    top: -100px; right: -80px;
    animation-delay: 0s;
  }
  .blob2 {
    width: 320px; height: 320px;
    background: rgba(247,67,138,.12);
    bottom: 0; right: 200px;
    animation-delay: -3s;
  }
  .blob3 {
    width: 260px; height: 260px;
    background: rgba(255,194,212,.25);
    top: 200px; left: -60px;
    animation-delay: -5s;
  }

  @keyframes float {
    0%, 100% { transform: translateY(0) scale(1); }
    50% { transform: translateY(-24px) scale(1.03); }
  }

  .hero-content {
    position: relative;
    max-width: 600px;
  }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: var(--rose-100);
    border: 1px solid rgba(247,67,138,.2);
    border-radius: 50px;
    padding: 6px 16px;
    font-size: 13px;
    font-weight: 500;
    color: var(--rose-600);
    margin-bottom: 28px;
    animation: fadeUp .6s ease both;
  }
  .hero-badge::before {
    content: '✦';
    font-size: 10px;
    color: var(--rose-400);
  }

  h1 {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(52px, 6vw, 80px);
    font-weight: 300;
    line-height: 1.05;
    color: var(--mocha);
    letter-spacing: -2px;
    margin-bottom: 24px;
    animation: fadeUp .7s .1s ease both;
  }

  h1 em {
    font-style: italic;
    color: var(--rose-500);
  }

  .hero-desc {
    font-size: 17px;
    line-height: 1.7;
    color: var(--dusty);
    font-weight: 300;
    max-width: 480px;
    margin-bottom: 40px;
    animation: fadeUp .7s .2s ease both;
  }

  .hero-actions {
    display: flex;
    gap: 16px;
    align-items: center;
    animation: fadeUp .7s .3s ease both;
  }

  .btn-lg {
    font-size: 15px;
    font-weight: 600;
    color: white;
    background: linear-gradient(135deg, #ff9cb9 0%, #f7438a 50%, #e0206e 100%);
    border: none;
    cursor: pointer;
    padding: 16px 36px;
    border-radius: 50px;
    box-shadow: 0 6px 24px rgba(247,67,138,.4);
    transition: transform .2s, box-shadow .2s;
  }
  .btn-lg:hover {
    transform: translateY(-3px);
    box-shadow: 0 12px 36px rgba(247,67,138,.5);
  }

  .hero-link {
    font-size: 15px;
    font-weight: 500;
    color: var(--mocha);
    text-decoration: none;
    display: flex;
    align-items: center;
    gap: 6px;
  }
  .hero-link::after { content: '→'; }
  .hero-link:hover { color: var(--rose-500); }

  .hero-stats {
    display: flex;
    gap: 40px;
    margin-top: 56px;
    animation: fadeUp .7s .4s ease both;
  }

  .stat { }
  .stat-num {
    font-family: 'Cormorant Garamond', serif;
    font-size: 36px;
    font-weight: 600;
    color: var(--mocha);
    line-height: 1;
  }
  .stat-num span { color: var(--rose-500); }
  .stat-label {
    font-size: 13px;
    color: var(--muted);
    margin-top: 4px;
    font-weight: 400;
  }

  /* hero visual */
  .hero-visual {
    position: absolute;
    right: 48px;
    top: 50%;
    transform: translateY(-50%);
    width: 460px;
    animation: fadeUp .8s .3s ease both;
  }

  .phone-mock {
    width: 280px;
    margin: 0 auto;
    background: white;
    border-radius: 36px;
    padding: 20px;
    box-shadow:
      0 40px 80px rgba(74,37,53,.15),
      0 0 0 1px rgba(255,156,185,.3),
      inset 0 1px 0 rgba(255,255,255,.8);
    position: relative;
    z-index: 1;
  }

  .phone-notch {
    width: 80px;
    height: 8px;
    background: var(--rose-100);
    border-radius: 50px;
    margin: 0 auto 16px;
  }

  .phone-now-playing {
    background: linear-gradient(135deg, var(--rose-100), var(--blush));
    border-radius: 20px;
    padding: 16px;
    margin-bottom: 14px;
    position: relative;
    overflow: hidden;
  }
  .phone-now-playing::before {
    content: '';
    position: absolute;
    top: -20px; right: -20px;
    width: 80px; height: 80px;
    background: rgba(247,67,138,.12);
    border-radius: 50%;
  }

  .pnp-tag {
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: var(--rose-500);
    font-weight: 600;
    margin-bottom: 8px;
  }
  .pnp-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: 16px;
    font-weight: 600;
    color: var(--mocha);
    line-height: 1.3;
  }
  .pnp-sub {
    font-size: 11px;
    color: var(--muted);
    margin-top: 4px;
  }

  .pnp-progress {
    margin-top: 12px;
    height: 3px;
    background: rgba(247,67,138,.15);
    border-radius: 10px;
  }
  .pnp-fill {
    height: 100%;
    width: 60%;
    background: linear-gradient(90deg, #ff9cb9, #f7438a);
    border-radius: 10px;
  }

  .pnp-controls {
    display: flex;
    justify-content: center;
    gap: 20px;
    margin-top: 12px;
    align-items: center;
  }
  .ctrl-btn {
    width: 28px; height: 28px;
    border-radius: 50%;
    background: var(--rose-100);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 12px;
    cursor: pointer;
    color: var(--rose-500);
  }
  .ctrl-play {
    width: 40px; height: 40px;
    background: linear-gradient(135deg, #ff9cb9, #f7438a);
    color: white;
    font-size: 14px;
  }

  .phone-section-title {
    font-size: 12px;
    font-weight: 600;
    color: var(--mocha);
    margin-bottom: 10px;
  }

  .phone-lecture-item {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 10px 0;
    border-bottom: 1px solid rgba(247,67,138,.08);
  }
  .phone-lecture-item:last-child { border-bottom: none; }

  .lecture-icon-sm {
    width: 36px; height: 36px;
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 16px;
    flex-shrink: 0;
  }
  .li-info { flex: 1; min-width: 0; }
  .li-name {
    font-size: 12px;
    font-weight: 500;
    color: var(--mocha);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .li-meta {
    font-size: 10px;
    color: var(--muted);
    margin-top: 2px;
  }
  .li-lock {
    font-size: 12px;
    color: var(--rose-300);
    flex-shrink: 0;
  }
  .li-free {
    font-size: 9px;
    background: var(--rose-100);
    color: var(--rose-500);
    font-weight: 600;
    padding: 2px 6px;
    border-radius: 50px;
    flex-shrink: 0;
  }

  /* floating cards */
  .float-card {
    position: absolute;
    background: white;
    border-radius: 16px;
    padding: 12px 16px;
    box-shadow: 0 8px 32px rgba(74,37,53,.12);
    border: 1px solid rgba(255,156,185,.2);
    font-size: 13px;
    animation: cardFloat 6s ease-in-out infinite;
  }
  .card-a {
    top: 60px; left: -60px;
    width: 160px;
    animation-delay: -2s;
  }
  .card-b {
    bottom: 80px; right: -40px;
    width: 150px;
    animation-delay: -4s;
  }
  @keyframes cardFloat {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-8px); }
  }
  .fc-label { font-size: 10px; color: var(--muted); margin-bottom: 4px; }
  .fc-val {
    font-family: 'Cormorant Garamond', serif;
    font-size: 22px;
    font-weight: 600;
    color: var(--mocha);
  }
  .fc-val span { color: var(--rose-500); }
  .fc-sub { font-size: 11px; color: var(--muted); }

  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(24px); }
    to { opacity: 1; transform: translateY(0); }
  }

  /* ── CATEGORIES ── */
  .section {
    padding: 100px 48px;
  }
  .section-header {
    text-align: center;
    margin-bottom: 60px;
  }
  .section-eyebrow {
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 2px;
    color: var(--rose-500);
    font-weight: 600;
    margin-bottom: 12px;
  }
  h2 {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(36px, 4vw, 54px);
    font-weight: 300;
    color: var(--mocha);
    letter-spacing: -1.5px;
    line-height: 1.1;
  }
  h2 em { font-style: italic; color: var(--rose-500); }

  .categories-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 16px;
  }

  .cat-card {
    background: white;
    border-radius: 24px;
    padding: 28px 24px;
    border: 1px solid rgba(255,156,185,.15);
    cursor: pointer;
    transition: transform .3s, box-shadow .3s, border-color .3s;
    position: relative;
    overflow: hidden;
  }
  .cat-card::before {
    content: '';
    position: absolute;
    inset: 0;
    opacity: 0;
    transition: opacity .3s;
  }
  .cat-card:hover {
    transform: translateY(-6px);
    box-shadow: 0 20px 48px rgba(247,67,138,.12);
    border-color: rgba(247,67,138,.25);
  }

  .cat-icon {
    width: 52px; height: 52px;
    border-radius: 16px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 26px;
    margin-bottom: 16px;
  }
  .cat-name {
    font-size: 15px;
    font-weight: 600;
    color: var(--mocha);
    margin-bottom: 6px;
  }
  .cat-count {
    font-size: 13px;
    color: var(--muted);
  }
  .cat-arrow {
    position: absolute;
    top: 20px; right: 20px;
    font-size: 16px;
    color: var(--rose-200);
    transition: color .2s, transform .2s;
  }
  .cat-card:hover .cat-arrow {
    color: var(--rose-400);
    transform: translate(3px, -3px);
  }

  /* ── FEATURED LECTURES ── */
  .lectures-scroll {
    display: flex;
    gap: 24px;
    overflow-x: auto;
    padding-bottom: 16px;
    scroll-snap-type: x mandatory;
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
  .lectures-scroll::-webkit-scrollbar { display: none; }

  .lecture-card {
    flex-shrink: 0;
    width: 300px;
    background: white;
    border-radius: 24px;
    overflow: hidden;
    border: 1px solid rgba(255,156,185,.15);
    transition: transform .3s, box-shadow .3s;
    scroll-snap-align: start;
    cursor: pointer;
  }
  .lecture-card:hover {
    transform: translateY(-6px);
    box-shadow: 0 20px 48px rgba(74,37,53,.12);
  }

  .lecture-cover {
    height: 160px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 52px;
    position: relative;
    overflow: hidden;
  }
  .lecture-cover::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(to bottom, transparent 40%, rgba(0,0,0,.1));
  }

  .lc-badge {
    position: absolute;
    top: 12px; left: 12px;
    background: rgba(255,255,255,.9);
    backdrop-filter: blur(8px);
    border-radius: 50px;
    padding: 4px 10px;
    font-size: 11px;
    font-weight: 600;
    color: var(--mocha);
    z-index: 1;
  }
  .lc-free-badge {
    position: absolute;
    top: 12px; right: 12px;
    background: linear-gradient(135deg, #ff9cb9, #f7438a);
    border-radius: 50px;
    padding: 4px 10px;
    font-size: 11px;
    font-weight: 600;
    color: white;
    z-index: 1;
  }

  .lecture-body {
    padding: 20px;
  }
  .lecture-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: 19px;
    font-weight: 600;
    color: var(--mocha);
    line-height: 1.3;
    margin-bottom: 8px;
  }
  .lecture-meta {
    display: flex;
    align-items: center;
    gap: 12px;
    font-size: 12px;
    color: var(--muted);
    margin-bottom: 14px;
  }
  .lecture-meta span { display: flex; align-items: center; gap: 4px; }

  .lecture-author {
    display: flex;
    align-items: center;
    gap: 8px;
    padding-top: 14px;
    border-top: 1px solid var(--rose-50);
  }
  .author-avatar {
    width: 28px; height: 28px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 12px;
    font-weight: 600;
    color: white;
  }
  .author-name { font-size: 12px; font-weight: 500; color: var(--mocha); }

  /* ── PRICING ── */
  .pricing-section {
    background: var(--blush);
    padding: 100px 48px;
  }

  .pricing-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
    max-width: 960px;
    margin: 0 auto;
  }

  .pricing-card {
    background: white;
    border-radius: 28px;
    padding: 36px 32px;
    border: 1px solid rgba(255,156,185,.2);
    position: relative;
    transition: transform .3s, box-shadow .3s;
  }
  .pricing-card:hover {
    transform: translateY(-6px);
    box-shadow: 0 24px 60px rgba(247,67,138,.12);
  }

  .pricing-card.popular {
    background: linear-gradient(155deg, #fff0f3 0%, #ffe8f0 100%);
    border: 2px solid rgba(247,67,138,.3);
    transform: scale(1.04);
  }
  .pricing-card.popular:hover { transform: scale(1.04) translateY(-6px); }

  .pop-badge {
    position: absolute;
    top: -14px; left: 50%;
    transform: translateX(-50%);
    background: linear-gradient(135deg, #ff9cb9, #f7438a);
    color: white;
    font-size: 12px;
    font-weight: 600;
    padding: 5px 18px;
    border-radius: 50px;
    white-space: nowrap;
  }

  .plan-name {
    font-size: 13px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: var(--rose-500);
    margin-bottom: 20px;
  }

  .plan-price {
    font-family: 'Cormorant Garamond', serif;
    font-size: 52px;
    font-weight: 300;
    color: var(--mocha);
    line-height: 1;
    margin-bottom: 4px;
  }
  .plan-price sup { font-size: 24px; vertical-align: top; margin-top: 10px; }
  .plan-period { font-size: 13px; color: var(--muted); margin-bottom: 28px; }

  .plan-features {
    list-style: none;
    margin-bottom: 32px;
  }
  .plan-features li {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    font-size: 14px;
    color: var(--text);
    margin-bottom: 12px;
    line-height: 1.4;
  }
  .plan-features li::before {
    content: '✓';
    color: var(--rose-500);
    font-weight: 700;
    flex-shrink: 0;
    margin-top: 1px;
  }
  .feat-dim { color: var(--muted) !important; }
  .plan-features .feat-dim::before { color: var(--rose-200) !important; }

  .btn-plan {
    width: 100%;
    padding: 14px;
    border-radius: 50px;
    font-size: 15px;
    font-weight: 600;
    cursor: pointer;
    transition: all .2s;
    border: none;
  }
  .btn-plan-outline {
    background: white;
    border: 2px solid rgba(247,67,138,.25);
    color: var(--rose-500);
  }
  .btn-plan-outline:hover { background: var(--rose-50); }

  .btn-plan-filled {
    background: linear-gradient(135deg, #ff9cb9, #f7438a);
    color: white;
    box-shadow: 0 6px 20px rgba(247,67,138,.35);
  }
  .btn-plan-filled:hover {
    box-shadow: 0 10px 30px rgba(247,67,138,.5);
    transform: translateY(-2px);
  }

  /* ── TESTIMONIALS ── */
  .testimonials-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }

  .testi-card {
    background: white;
    border-radius: 24px;
    padding: 28px;
    border: 1px solid rgba(255,156,185,.15);
  }

